FROM python:3.12-slim

# The NIFTY 200 scan is research/paper-trading only. Credentials are supplied
# at runtime through --env-file; this image never copies a .env file.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    MODE=PAPER

WORKDIR /app

# tzdata supplies Asia/Kolkata for Friday market-close checks.
RUN apt-get update \
    && apt-get install --no-install-recommends -y tzdata \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /usr/sbin/nologin tradebot

COPY requirements.txt ./
RUN pip install --requirement requirements.txt

# Explicit copies prevent .env, AWS credentials, reports, caches, and local
# virtual environments from being included in the image.
COPY *.py ./
COPY backtest ./backtest
COPY broker ./broker
COPY core ./core
COPY data ./data
COPY execution ./execution
COPY indicators ./indicators
COPY scanner ./scanner
COPY strategy ./strategy

RUN mkdir -p cache database logs reports \
    && chown -R tradebot:tradebot /app

USER tradebot

# Run after Friday's market close. This creates reports/swing_rotation_targets.csv
# and exits; it never submits a broker order.
CMD ["python", "run_swing_rotation_targets.py", "--refresh-current"]
